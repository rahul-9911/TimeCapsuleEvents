# ── App ──────────────────────────────────────────────────────────────────────
ENV=dev                          # dev | staging | prod
BASE_URL=http://localhost:80     # Public-facing URL (used in magic links)
SECRET_KEY=change-me-to-a-long-random-string

# ── Control Plane DB (PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/snapevent

# ── Gmail SMTP (magic link emails) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password   # Generate at: myaccount.google.com/apppasswords
SMTP_FROM=your-gmail@gmail.com

# ── Object Storage ───────────────────────────────────────────────────────────
S3_BUCKET=snapevent-dev
S3_ENDPOINT=http://minio:9000       # Leave blank on AWS (uses default boto3 endpoint)
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin        # Use real IAM keys on AWS
AWS_SECRET_ACCESS_KEY=minioadmin

# ── EFS / Local Storage ───────────────────────────────────────────────────────
EFS_MOUNT=/efs                      # Mount path inside containers (local: Docker volume)

# ── Container Spawner ────────────────────────────────────────────────────────
EVENT_IMAGE=snapevent-event:latest  # Docker image name for event containers
DOCKER_NETWORK=snapevent_default    # Docker Compose network name (auto-set by Compose)

# ── AWS (only needed when ENV != dev) ────────────────────────────────────────
# AWS_REGION=us-east-1
# ECS_CLUSTER=snapevent-staging
# EVENT_TASK_DEFINITION=snapevent-event-staging
# ECS_SUBNETS=subnet-xxx,subnet-yyy
# EVENT_SECURITY_GROUP=sg-xxx
