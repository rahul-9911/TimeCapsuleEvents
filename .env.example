# ── App ──────────────────────────────────────────────────────────────────────
ENV=dev
BASE_URL=https://xxxxx.execute-api.us-east-1.amazonaws.com  # Set after terraform apply
SECRET_KEY=38fbba38976fcf321b11cbf3a795408621f9d81cc28689c6ee713250438f6f66

# ── DynamoDB ─────────────────────────────────────────────────────────────────
